{
  "name": "design-ictsite-wp-theme",
  "version": "DEV-0.1.8",
  "description": "WordPress theme for ICT sites",
  "main": "index.js",
  "scripts": {
    "build": "npm run minify:css && npm run minify:js",
    "lint": "npm run lint:php",
    "lint:php": "composer run lint:php -- .",
    "lint:php:file": "composer run lint:php --",
    "lint:php:fix": "composer run lint:php:fix -- .",
    "lint:php:fix:file": "composer run lint:php:fix --",
    "version": "node scripts/config-sync && git add style.css && git add README.md",
    "postversion": "echo \"You can now publish your tag with 'git push --follow-tags'\"",
    "minify:css": "node scripts/minify-css.js",
    "minify:js": "node scripts/minify-js.js",
		"create_layout": "sass --load-path=node_modules assets/scss/bootstrap-italia-custom.scss:assets/css/compiled/bootstrap-italia-custom.min.css --style=compressed",
		"update_layout_win": "npm run create_layout && xcopy .\\assets\\css\\compiled\\bootstrap-italia-custom.min.* .\\assets\\css\\ /Y",
		"update_layout_linux": "npm run create_layout && cp -f ./assets/css/compiled/bootstrap-italia-custom.min.* ./assets/css/",
    "status:scan:install-browser": "npx playwright install chromium",
    "status:compare": "node tests/e2e/status-report/compare.js",
    "quality:scan": "node tests/e2e/quality-report/scan.js",
    "quality:scan:gate": "node tests/e2e/quality-report/scan.js --gate",
    "quality:compare": "node tests/e2e/quality-report/compare.js",
    "ux:scan": "node tests/e2e/ux-report/scan.js",
    "ux:scan:gate": "node tests/e2e/ux-report/scan.js --gate",
    "ux:compare": "node tests/e2e/ux-report/compare.js",
    "html:scan": "node tests/e2e/html-report/scan.js",
    "html:scan:gate": "node tests/e2e/html-report/scan.js --gate",
    "html:compare": "node tests/e2e/html-report/compare.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ScuolaNormaleSuperiore/design-ictsite-wp-theme.git"
  },
  "author": "Servizi Informativi SNS",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/ScuolaNormaleSuperiore/design-ictsite-wp-theme/issues"
  },
  "homepage": "https://github.com/ScuolaNormaleSuperiore/design-ictsite-wp-theme/#readme",
  "dependencies": {
    "bootstrap-italia": "^2.18.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "clean-css-cli": "^5.6.1",
    "playwright": "^1.50.0",
    "replace-in-file": "^6.3.5",
    "sass": "^1.81.0",
    "uglify-js": "^3.17.4",
    "vnu-jar": "^26.3.17"
  }
}
